{
  "expo": {
    "name": "Coinly",
    "slug": "Coinly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icono.png",
    "scheme": "coinly",
    "userInterfaceStyle": "automatic",
    "owner": "anthony117",
    "ios": {
      "icon": "./assets/icono.png"
    },
    "android": {
      "package": "com.anthony117.coinly",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icono.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "notification": {
      "icon": "./assets/icono-notificacion.png",
      "color": "#208AEF"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icono.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/icono.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icono-notificacion.png",
          "color": "#208AEF"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "813c50cf-3227-4734-b814-2d55d2d9e6b5"
      }
    }
  }
}
