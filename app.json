{
  "expo": {
    "name": "SoinT",
    "slug": "SoinT",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icono.png",
    "scheme": "soint",
    "userInterfaceStyle": "automatic",
    "owner": "anthony117",
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#208AEF"
    },
    "ios": {
      "icon": "./assets/icono.png"
    },
    "android": {
      "package": "com.anthony117.coinly",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icono.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icono.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/icono.png",
          "imageWidth": 200
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8770610388319332~4020475367",
          "iosAppId": "ca-app-pub-8770610388319332~4020475367"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#208AEF"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "813c50cf-3227-4734-b814-2d55d2d9e6b5"
      }
    }
  }
}
